                }
              ]
            },
            "valueString": "Patient has encephalopathy"
          },
          {
            "code": {
              "coding": [
                {
                  "code": "51967-8",
                  "display": "Genetic disease(s) assessed",
                  "system": "http://loinc.org"
                }
              ]
            },
            "valueCodeableConcept": {
              "coding": [
                {
                  "code": "R377",
                  "display": "Intellectual disability – microarray only",
                  "system": "https://fhir.nwgenomics.nhs.uk/CodeSystem/GenomicClinicalIndication"
                }
              ]
            }
          },
          {
            "code": {
              "coding": [
                {
                  "code": "81293-3",
                  "display": "Description of ranges of DNA sequences examined",
                  "system": "http://loinc.org"
                }
              ]
            },
            "valueString": "Whole genome coverage, including subtelomeric and pericentromeric regions. Affymetrix Cytogenetics platform contains >2.1 million copy-number markers, including 750,000 single- nucleotide polymorphism (SNP) probes to detect copy number changes and LCSH."
          },
          {
            "code": {
              "coding": [
                {
                  "code": "83006-7",
                  "display": "Deletion-duplication overall interpretation",
                  "system": "http://loinc.org"
                }
              ]
            },
            "valueCodeableConcept": {
              "coding": [
                {
                  "code": "LA26804-7",
                  "display": "Deletion and/or duplication detected in studied region",
                  "system": "http://loinc.org"
                }
              ]
            }
          },
          {
            "code": {
              "coding": [
                {
                  "code": "51969-4",
                  "display": "Full narrative report",
                  "system": "http://loinc.org"
                }
              ]
            },
            "valueString": "Genetic Results: The cytogenomic microarray analysis indicated that there was a gain involving chromosome 16 (1.7 Mb duplicated) within 16p13.11, suggesting partial trisomy for this region. This duplication has been reported as a risk factor for neurocognitive disorders as it appears to be enriched in children with intellectual disabilities, but is also observed, at a lower frequency, in normal individuals. \r\n\r\n Method: CHROMOSOMAL MICROARRAY ANALYSIS (CMA). \r\n\r\n Methodology: This CMA was performed using Affymetrix(R) Cytogenetics Whole-Genome 2.7M Array. The array offers a total of 2,141,868 markers across the entire genome, including 1,742,975 unique non-polymorphic markers, and 398,891 SNP markers."
          },
          {
            "code": {
              "coding": [
                {
                  "code": "81291-7",
                  "display": "Structural variant ISCN",
                  "system": "http://loinc.org"
                }
              ]
            },
            "valueString": "arr16p13.11(14,686,844x2,14776269-16486370x3,16,494,405x2)(hg18)^ISCN"
          },
          {
            "code": {
              "coding": [
                {
                  "code": "62374-4",
                  "display": "Human reference sequence assembly",
                  "system": "http://loinc.org"
                }
              ]
            },
            "valueCodeableConcept": {
              "coding": [
                {
                  "code": "LA26805-4",
                  "display": "NCBI36",
                  "system": "http://loinc.org"
                }
              ]
            }
          }
        ],
